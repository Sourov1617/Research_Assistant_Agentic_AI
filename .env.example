# ============================================================
# Intelligent Research Discovery & Synthesis Agent - Config
# Copy this file to .env and fill in your credentials
# ============================================================

# ------------------------------------------------------------
# LLM PROVIDER SELECTION
# Options: openai | azure_openai | openrouter | gemini | anthropic | groq
# ------------------------------------------------------------
LLM_PROVIDER=openai

# Default model name (overridden per-provider below)
DEFAULT_MODEL=gpt-4o-mini

# ------------------------------------------------------------
# OPENAI
# ------------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# ------------------------------------------------------------
# AZURE OPENAI
# ------------------------------------------------------------
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_API_VERSION=2025-01-01-preview
# Azure deployment name can differ from the underlying model name.
AZURE_OPENAI_DEPLOYMENT=gpt-35-turbo
AZURE_OPENAI_DEFAULT_MODEL=gpt-4.1-mini

# ------------------------------------------------------------
# OPENROUTER (access 100+ models via single API)
# Get key at: https://openrouter.ai/keys
# ------------------------------------------------------------
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=meta-llama/llama-3.1-8b-instruct:free
# Other popular free models on OpenRouter:
# google/gemma-2-9b-it:free
# mistralai/mistral-7b-instruct:free
# nousresearch/hermes-3-llama-3.1-405b:free

# ------------------------------------------------------------
# GOOGLE GEMINI
# Get key at: https://aistudio.google.com/app/apikey
# ------------------------------------------------------------
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_DEFAULT_MODEL=gemini-2.0-flash

# ------------------------------------------------------------
# ANTHROPIC (Claude)
# Get key at: https://console.anthropic.com/
# ------------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_DEFAULT_MODEL=claude-3-haiku-20240307


# ------------------------------------------------------------
# RESEARCH RETRIEVAL APIs
# ------------------------------------------------------------

# Semantic Scholar API (free, no key required for basic use)
# Register for higher rate limits: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_api_key_here
SEMANTIC_SCHOLAR_BASE_URL=https://api.semanticscholar.org/graph/v1

# arXiv API (completely free, no key required)
ARXIV_BASE_URL=http://export.arxiv.org/api/query
ARXIV_MAX_RESULTS=15

# CORE API (open access papers)
# Register at: https://core.ac.uk/services/api
CORE_API_KEY=your_core_api_key_here
CORE_BASE_URL=https://api.core.ac.uk/v3

# CrossRef API (free, optional key for higher limits)
# Register at: https://www.crossref.org/documentation/polite-pool/
CROSSREF_EMAIL=your_email@example.com
CROSSREF_BASE_URL=https://api.crossref.org/works

# ------------------------------------------------------------
# WEB SEARCH (for industry posts, blogs, GitHub)
# ------------------------------------------------------------

# Tavily AI Search (recommended - research-optimized)
# Get free key at: https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here
TAVILY_BASE_URL=https://api.tavily.com

# SerpAPI (alternative web search)
# Get key at: https://serpapi.com
SERPAPI_API_KEY=your_serpapi_key_here

# DuckDuckGo Search (free fallback, no key required)
USE_DUCKDUCKGO_FALLBACK=true

# ------------------------------------------------------------
# VECTOR STORE & EMBEDDINGS
# ------------------------------------------------------------
# Vector store: llamaindex | llamacloud | faiss | chroma
#   * llamaindex  - local llama-index on‑disk index (preferred)
#   * llamacloud   - remote index hosted by LlamaCloud (requires API key)
#   * faiss/chroma - legacy LangChain stores (kept for backward compatibility)
VECTOR_STORE_TYPE=llamaindex
VECTOR_STORE_PATH=./data/vector_store

# Embedding provider: openai | huggingface
# NOTE: llamaindex backends manage embeddings internally; settings
# below are only used by the legacy faiss/chroma paths.
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# OpenAI embedding model (if using openai embeddings)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# llama-index / LlamaCloud configuration
# LLAMA_CLOUD_API_KEY should be set when VECTOR_STORE_TYPE=llamacloud
LLAMA_CLOUD_API_KEY=
LLAMA_CLOUD_INDEX_NAME=research_papers
LLAMA_CLOUD_PROJECT_NAME=Default

# ------------------------------------------------------------
# MEMORY CONFIGURATION
# ------------------------------------------------------------
MEMORY_ENABLED_DEFAULT=false
MEMORY_BACKEND=sqlite
# SQLite database path
SQLITE_DB_PATH=./data/memory/research_memory.db
# JSON memory path (alternative)
JSON_MEMORY_PATH=./data/memory/sessions/
# Max conversation turns to retain in context
MAX_MEMORY_TURNS=20
# Max papers to track in memory per session
MAX_PAPERS_IN_MEMORY=100

# ------------------------------------------------------------
# AGENT BEHAVIOR SETTINGS
# ------------------------------------------------------------
# Max papers to retrieve per source
MAX_PAPERS_PER_SOURCE=10
# Max total papers after ranking
MAX_RANKED_PAPERS=15
# Minimum relevance score to include paper (0.0 - 1.0)
MIN_RELEVANCE_SCORE=0.3
# Temperature for LLM calls (0.0 = deterministic)
LLM_TEMPERATURE=0.2
# Max tokens for synthesis per paper
MAX_SYNTHESIS_TOKENS=500
# Max tokens for research insights
MAX_INSIGHTS_TOKENS=800

# ------------------------------------------------------------
# STREAMLIT APP SETTINGS
# ------------------------------------------------------------
APP_TITLE=Research Discovery & Synthesis Agent
APP_ICON=🔬
APP_THEME=dark
# Maximum query length in characters
MAX_QUERY_LENGTH=5000
# Show debug info in UI
DEBUG_MODE=false

# ------------------------------------------------------------
# FASTAPI / EVENT STREAMING SETTINGS
# ------------------------------------------------------------
API_CORS_ORIGINS=*

# ------------------------------------------------------------
# KAFKA SETTINGS (optional)
# ------------------------------------------------------------
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_PREFIX=research_assistant
